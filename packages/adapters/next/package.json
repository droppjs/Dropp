{
  "name": "@usedropp/adapter-next",
  "version": "0.1.0",
  "author": "Ribal Arshad",
  "description": "Next.js adapter for Dropp media management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "next": "^14.0.0"
  },
  "dependencies": {
    "@usedropp/core": "workspace:*",
    "@usedropp/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "next": "^14.0.0",
    "typescript": "^5.3.3"
  }
}
